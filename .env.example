# Copy to .env (gitignored) and export before running Mnemos:
#   set -a; source .env; set +a
# Mnemos reads these from the environment; it does not auto-load .env.

# --- Model backend: stub (offline default) or http (/chat/completions endpoint) ---
# MNEMOS_MODEL_BACKEND=http
# MNEMOS_MODEL_BASE_URL=http://localhost:11434/v1
# MNEMOS_MODEL_NAME=qwen2.5-coder:7b-instruct
# MNEMOS_MODEL_TIMEOUT=600

# --- Local budget guard ---
# MNEMOS_MAX_PER_MIN=60
# MNEMOS_TOKEN_BUDGET=200000

# --- Real audio (install a local engine first) ---
# MNEMOS_TTS_CMD=<a CLI that reads text on stdin and speaks>
# MNEMOS_STT_CMD=<a CLI that takes a wav path and prints a transcript>
